import { LineEdit, Palette, ScrollView } from "std-widgets.slint";
import "fonts/InstrumentSans[wdth,wght].ttf";
import "fonts/JetBrainsMono[wght].ttf";
import { DigestRow, TopicRow, ChatRow, EvidencePostRow, EvidenceRow } from "models.slint";
import { Tokens } from "theme.slint";
import { ChevronIconButton, CloseIconButton } from "icons.slint";

component MobileMonoLabel inherits Text {
    color: Tokens.ink-3;
    font-family: "JetBrains Mono";
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 1.1px;
}

component MobileSpark inherits Rectangle {
    in property <string> line-path: "M3 31 L113 31";
    in property <string> area-path: "M3 31 L113 31 L113 31 L3 31 Z";
    in property <float> end-x: 113;
    in property <float> end-y: 31;
    in property <color> tone: Tokens.rise;

    background: transparent;
    Path {
        width: parent.width;
        height: parent.height;
        viewbox-width: 116;
        viewbox-height: 34;
        fit: fill;
        fill: Tokens.rise-soft;
        stroke: transparent;
        commands: root.area-path;
    }
    Path {
        width: parent.width;
        height: parent.height;
        viewbox-width: 116;
        viewbox-height: 34;
        fit: fill;
        fill: transparent;
        stroke: root.tone;
        stroke-width: 2px;
        stroke-line-cap: round;
        stroke-line-join: round;
        commands: root.line-path;
    }
    Rectangle {
        x: parent.width * root.end-x / 116 - self.width / 2;
        y: parent.height * root.end-y / 34 - self.height / 2;
        width: 6px;
        height: 6px;
        border-radius: 3px;
        border-width: 1px;
        border-color: Tokens.surface;
        background: root.tone;
    }
}

component MobileDigestCard inherits Rectangle {
    in property <DigestRow> data;
    in property <int> rank;
    in property <bool> selected: false;
    in property <color> topic-color: data.id == "rust" ? Tokens.rust :
        data.id == "local-first" ? Tokens.local :
        data.id == "ai-infra" ? Tokens.ai :
        data.id == "wasm-runtimes" ? Tokens.wasm : Tokens.steel;
    callback explain();
    callback subscribe();
    callback open-url(string);

    height: 112px;
    border-radius: 14px;
    border-width: 1px;
    border-color: root.selected ? Tokens.accent : Tokens.line;
    background: Tokens.surface;

    Text {
        x: 13px;
        y: 12px;
        width: 22px;
        height: 14px;
        text: root.rank < 10 ? "0" + root.rank : root.rank;
        color: Tokens.ink-3;
        font-family: "JetBrains Mono";
        font-size: 10px;
        font-weight: 650;
    }
    Rectangle {
        x: 39px;
        y: 15px;
        width: 7px;
        height: 7px;
        border-radius: 2px;
        background: root.topic-color;
    }
    Text {
        x: 51px;
        y: 10px;
        width: 126px;
        height: 18px;
        text: data.id == "wasm-runtimes" ? "wasm" : data.id;
        color: Tokens.ink-2;
        font-family: "JetBrains Mono";
        font-size: 10px;
        vertical-alignment: center;
    }
    Text {
        x: parent.width - 100px;
        y: 10px;
        width: 87px;
        height: 18px;
        text: data.delta;
        color: Tokens.rise;
        font-family: "JetBrains Mono";
        font-size: 9px;
        font-weight: 700;
        horizontal-alignment: right;
        vertical-alignment: center;
    }
    Text {
        x: 13px;
        y: 34px;
        width: parent.width - 26px;
        height: 38px;
        text: data.headline;
        color: Tokens.ink;
        font-size: 13px;
        font-weight: 620;
        wrap: word-wrap;
        overflow: elide;
    }
    Rectangle {
        x: 13px;
        y: 70px;
        width: parent.width - 26px;
        height: 1px;
        background: headline-touch.has-hover ? Tokens.accent : transparent;
    }
    headline-touch := TouchArea {
        x: 13px;
        y: 34px;
        width: parent.width - 26px;
        height: 38px;
        mouse-cursor: pointer;
        clicked => { root.open-url(data.url); }
    }
    Text {
        x: 13px;
        y: 79px;
        width: parent.width - 205px;
        height: 19px;
        text: data.sources;
        color: Tokens.ink-2;
        font-size: 10px;
        overflow: elide;
        vertical-alignment: center;
    }
    MobileSpark {
        x: parent.width - 176px;
        y: 73px;
        width: 74px;
        height: 24px;
        line-path: data.spark-line;
        area-path: data.spark-area;
        end-x: data.spark-end-x;
        end-y: data.spark-end-y;
    }
    Text {
        x: parent.width - 94px;
        y: 78px;
        width: 42px;
        height: 20px;
        text: "track";
        color: Tokens.ink-2;
        font-family: "JetBrains Mono";
        font-size: 8px;
        vertical-alignment: center;
        TouchArea { clicked => { root.subscribe(); } }
    }
    ChevronIconButton {
        x: parent.width - 42px;
        y: 75px;
        open: root.selected;
        clicked => { root.explain(); }
    }
}

component MobileTopicChannel inherits Rectangle {
    in property <TopicRow> data;
    in property <color> topic-color: data.id == "rust" ? Tokens.rust :
        data.id == "local-first" ? Tokens.local :
        data.id == "ai-infra" ? Tokens.ai :
        data.id == "wasm-runtimes" ? Tokens.wasm : Tokens.steel;
    in property <float> visual-weight: (data.weight-value + 1.0) / 3.0;
    callback set-weight(float);

    height: 66px;
    border-radius: 14px;
    border-width: 1px;
    border-color: Tokens.line;
    background: Tokens.surface;
    opacity: data.muted ? 0.55 : 1;

    Rectangle {
        x: 0;
        width: 3px;
        height: parent.height;
        border-radius: 2px;
        background: root.topic-color;
    }
    Text {
        x: 14px;
        y: 9px;
        width: 168px;
        height: 20px;
        text: data.id == "wasm-runtimes" ? "wasm" : data.id;
        color: Tokens.ink;
        font-family: "JetBrains Mono";
        font-size: 12px;
        font-weight: 650;
        vertical-alignment: center;
    }
    Text {
        x: parent.width - 82px;
        y: 9px;
        width: 36px;
        height: 20px;
        text: data.muted ? "off" : data.weight;
        color: Tokens.ink-2;
        font-family: "JetBrains Mono";
        font-size: 10px;
        horizontal-alignment: right;
        vertical-alignment: center;
    }
    mute := Rectangle {
        x: parent.width - 39px;
        y: 6px;
        width: 30px;
        height: 30px;
        border-radius: 8px;
        border-width: 1px;
        border-color: data.muted ? root.topic-color : Tokens.line-strong;
        background: data.muted ? root.topic-color : Tokens.raised;
        Text {
            text: "M";
            color: data.muted ? #FFFFFF : Tokens.ink-3;
            font-family: "JetBrains Mono";
            font-size: 10px;
            font-weight: 700;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
        TouchArea { clicked => { root.set-weight(data.muted ? 0.0 : -1.0); } }
    }
    fader := Rectangle {
        x: 14px;
        y: 33px;
        width: parent.width - 28px;
        height: 30px;
        background: transparent;
        Rectangle {
            x: 0;
            y: 12px;
            width: parent.width;
            height: 5px;
            border-radius: 3px;
            background: Tokens.inset;
        }
        Rectangle {
            x: 0;
            y: 12px;
            width: parent.width * root.visual-weight;
            height: 5px;
            border-radius: 3px;
            background: root.topic-color;
        }
        Rectangle {
            x: (parent.width - self.width) * root.visual-weight;
            y: 4px;
            width: 21px;
            height: 21px;
            border-radius: 11px;
            border-width: 2px;
            border-color: root.topic-color;
            background: Tokens.surface;
        }
        TouchArea {
            clicked => { root.set-weight(self.mouse-x / self.width * 3.0 - 1.0); }
        }
    }
}

component MobileAttentionBudgetMaster inherits Rectangle {
    in property <int> budget: 5;
    in property <int> count: 0;
    private property <float> level: min(1, max(0, (root.budget - 3) / 7));
    callback set-budget(int);

    height: 82px;
    border-radius: 14px;
    border-width: 1px;
    border-color: Tokens.accent;
    background: Tokens.accent-soft;

    Rectangle {
        x: 0;
        width: 4px;
        height: parent.height;
        border-radius: 2px;
        background: Tokens.accent;
    }
    Text {
        x: 14px;
        y: 8px;
        width: parent.width - 74px;
        height: 18px;
        text: "ATTENTION BUDGET";
        color: Tokens.accent;
        font-family: "JetBrains Mono";
        font-size: 9px;
        font-weight: 750;
        vertical-alignment: center;
    }
    Text {
        x: parent.width - 52px;
        y: 8px;
        width: 38px;
        height: 18px;
        text: root.budget;
        color: Tokens.accent;
        font-family: "JetBrains Mono";
        font-size: 12px;
        font-weight: 750;
        horizontal-alignment: right;
        vertical-alignment: center;
    }
    budget-fader := Rectangle {
        x: 14px;
        y: 27px;
        width: parent.width - 28px;
        height: 28px;
        background: transparent;
        Rectangle {
            y: 12px;
            width: parent.width;
            height: 5px;
            border-radius: 3px;
            background: Tokens.inset;
        }
        Rectangle {
            y: 12px;
            width: parent.width * root.level;
            height: 5px;
            border-radius: 3px;
            background: Tokens.accent;
        }
        Rectangle {
            x: (parent.width - self.width) * root.level;
            y: 4px;
            width: 21px;
            height: 21px;
            border-radius: 11px;
            border-width: 2px;
            border-color: Tokens.accent;
            background: Tokens.surface;
        }
        TouchArea {
            clicked => {
                root.set-budget(min(10, max(3, round(3 + self.mouse-x / self.width * 7))));
            }
        }
    }
    Text {
        x: 14px;
        y: 58px;
        width: parent.width - 28px;
        height: 13px;
        text: root.count + " / " + root.budget + " surfaced";
        color: Tokens.ink-2;
        font-family: "JetBrains Mono";
        font-size: 8px;
    }
}

component MobileChatMessage inherits Rectangle {
    in property <ChatRow> data;
    height: content.preferred-height;
    background: transparent;

    content := VerticalLayout {
        width: root.width;
        spacing: 4px;
        MobileMonoLabel {
            text: data.role;
            color: data.role == "YOU" ? Tokens.steel :
                data.role == "TOOL" ? Tokens.accent : Tokens.ink-3;
        }
        if data.role == "TOOL": Rectangle {
            height: 28px;
            background: Tokens.accent-soft;
            border-radius: 4px;
            Rectangle { x: 0; width: 3px; height: parent.height; background: Tokens.accent; }
            Text {
                x: 10px;
                width: parent.width - 18px;
                text: "↳ " + data.tool + " · " + data.body;
                color: Tokens.accent;
                font-family: "JetBrains Mono";
                font-size: 8.5px;
                overflow: elide;
                vertical-alignment: center;
            }
        }
        Text {
            visible: data.role != "TOOL";
            width: root.width;
            text: data.body;
            color: Tokens.ink-2;
            font-size: 12px;
            wrap: word-wrap;
        }
    }
}

component MobileEvidenceSheet inherits Rectangle {
    in property <EvidenceRow> data;
    in property <[EvidencePostRow]> posts;
    in property <bool> side-panel: false;
    in property <length> available-height: 430px;
    callback close();
    callback open-url(string);

    height: root.side-panel ? root.available-height : 430px;
    border-radius: root.side-panel ? 18px : 24px;
    background: Tokens.surface;
    border-width: 1px;
    border-color: Tokens.line-strong;
    clip: true;

    TouchArea { }
    VerticalLayout {
        padding-left: 17px;
        padding-right: 17px;
        padding-top: root.side-panel ? 8px : 10px;
        padding-bottom: root.side-panel ? 8px : 16px;
        spacing: root.side-panel ? 6px : 10px;
        Rectangle {
            height: root.side-panel ? 0px : 7px;
            visible: !root.side-panel;
            background: transparent;
            Rectangle {
                x: (parent.width - self.width) / 2;
                width: 42px;
                height: 4px;
                border-radius: 2px;
                background: Tokens.line-strong;
            }
        }
        HorizontalLayout {
            height: 26px;
            MobileMonoLabel { text: "WHY THIS IS MOVING"; horizontal-stretch: 1; }
            CloseIconButton {
                clicked => { root.close(); }
            }
        }
        Text {
            height: 24px;
            text: data.topic;
            color: Tokens.ink;
            font-size: 17px;
            font-weight: 680;
        }
        Rectangle {
            height: root.side-panel ? 58px : 72px;
            background: Tokens.raised;
            border-radius: 10px;
            MobileSpark {
                x: 9px;
                y: 9px;
                width: parent.width - 18px;
                height: 50px;
                tone: Tokens.accent;
                line-path: data.spark-line;
                area-path: data.spark-area;
                end-x: data.spark-end-x;
                end-y: data.spark-end-y;
            }
        }
        HorizontalLayout {
            height: root.side-panel ? 34px : 40px;
            spacing: 8px;
            for stat in ["6H\n" + data.mentions, "BASE\n" + data.baseline-value, "Z\n" + data.z-score, "SOURCES\n" + data.source-count]: Text {
                text: stat;
                color: Tokens.ink-2;
                font-family: "JetBrains Mono";
                font-size: 8.5px;
                horizontal-stretch: 1;
            }
        }
        Text {
            height: 14px;
            text: data.baseline;
            color: Tokens.ink-3;
            font-family: "JetBrains Mono";
            font-size: 8px;
            overflow: elide;
        }
        VerticalLayout {
            height: root.posts.length * (root.side-panel ? 30px : 36px);
            spacing: 0px;
            for post in root.posts: Rectangle {
                height: root.side-panel ? 30px : 36px;
                border-width: 1px;
                border-color: Tokens.line;
                background: Tokens.surface;
                Text {
                    x: 8px;
                    width: 68px;
                    text: post.source;
                    color: Tokens.ink-3;
                    font-family: "JetBrains Mono";
                    font-size: 8px;
                    overflow: elide;
                    vertical-alignment: center;
                }
                Text {
                    x: 79px;
                    width: parent.width - 88px;
                    text: post.title;
                    color: Tokens.ink-2;
                    font-size: 9.5px;
                    overflow: elide;
                    vertical-alignment: center;
                }
                Rectangle {
                    y: parent.height - 1px;
                    width: parent.width;
                    height: 1px;
                    background: post-touch.has-hover ? Tokens.accent : transparent;
                }
                post-touch := TouchArea {
                    mouse-cursor: pointer;
                    clicked => { root.open-url(post.url); }
                }
            }
        }
        Text {
            text: "rank = trend × interest · velocity + z-score + sources";
            color: Tokens.ink-3;
            font-family: "JetBrains Mono";
            font-size: 7.5px;
            horizontal-alignment: center;
        }
    }
}

component MobileHeader inherits Rectangle {
    in property <bool> compact: false;
    in property <int> count: 0;
    in property <int> budget: 5;
    height: root.compact ? 52px : 76px;
    background: Tokens.ground;
    Text {
        x: 16px;
        y: 8px;
        width: 220px;
        height: 25px;
        text: "Community Pulse";
        color: Tokens.ink;
        font-size: 16px;
        font-weight: 680;
        vertical-alignment: center;
    }
    Text {
        x: parent.width - 72px;
        y: 10px;
        width: 56px;
        height: 22px;
        text: "●  LIVE";
        color: Tokens.ok;
        font-family: "JetBrains Mono";
        font-size: 8px;
        font-weight: 700;
        horizontal-alignment: right;
        vertical-alignment: center;
    }
    Path {
        x: 16px;
        y: root.compact ? 29px : 36px;
        width: parent.width - 32px;
        height: root.compact ? 16px : 23px;
        viewbox-width: 320;
        viewbox-height: 26;
        fit: fill;
        fill: transparent;
        stroke: Tokens.accent;
        stroke-width: 1.6px;
        stroke-line-cap: round;
        stroke-line-join: round;
        commands: "M0 14 L66 14 L72 14 L78 5 L84 22 L90 11 L96 14 L158 14 L164 14 L170 3 L176 24 L182 10 L188 14 L252 14 L258 14 L264 6 L270 21 L276 12 L282 14 L320 14";
    }
    MobileMonoLabel {
        visible: !root.compact;
        x: 16px;
        y: 61px;
        text: "TODAY'S PULSE  ·  " + root.count + " / " + root.budget;
    }
}

component PhoneStatusBar inherits Rectangle {
    in property <string> time: "09:41";
    height: 28px;
    background: Tokens.surface;

    Text {
        x: 18px;
        width: 48px;
        text: root.time;
        color: Tokens.ink;
        font-family: "JetBrains Mono";
        font-size: 9px;
        font-weight: 700;
        vertical-alignment: center;
    }

    Rectangle {
        x: (parent.width - self.width) / 2;
        y: 4px;
        width: 74px;
        height: 18px;
        border-radius: 10px;
        background: #05070A;
        Rectangle {
            x: parent.width - 18px;
            y: 7px;
            width: 4px;
            height: 4px;
            border-radius: 2px;
            background: #243040;
        }
    }

    HorizontalLayout {
        x: parent.width - 76px;
        y: 8px;
        width: 58px;
        height: 11px;
        spacing: 5px;
        Text {
            text: "5G";
            color: Tokens.ink-2;
            font-family: "JetBrains Mono";
            font-size: 7px;
            font-weight: 700;
            vertical-alignment: center;
        }
        Rectangle {
            width: 15px;
            height: 9px;
            background: transparent;
            Rectangle { x: 0px; y: 6px; width: 2px; height: 3px; border-radius: 1px; background: Tokens.ink-2; }
            Rectangle { x: 4px; y: 4px; width: 2px; height: 5px; border-radius: 1px; background: Tokens.ink-2; }
            Rectangle { x: 8px; y: 2px; width: 2px; height: 7px; border-radius: 1px; background: Tokens.ink-2; }
            Rectangle { x: 12px; y: 0px; width: 2px; height: 9px; border-radius: 1px; background: Tokens.ink-2; }
        }
        Rectangle {
            width: 20px;
            height: 9px;
            border-radius: 2px;
            border-width: 1px;
            border-color: Tokens.ink-2;
            background: transparent;
            Rectangle {
                x: 2px;
                y: 2px;
                width: 14px;
                height: 3px;
                border-radius: 1px;
                background: Tokens.ink-2;
            }
        }
    }
}

export component MobileWindow inherits Window {
    title: "Community Pulse · Mobile";
    no-frame: true;
    preferred-width: root.landscape ? 872px : 418px;
    preferred-height: root.landscape ? 418px : 872px;
    min-width: root.landscape ? 872px : 418px;
    min-height: root.landscape ? 418px : 872px;
    max-width: root.landscape ? 872px : 418px;
    max-height: root.landscape ? 418px : 872px;
    background: #11151C;
    default-font-family: "Instrument Sans";
    forward-focus: key-handler;

    in-out property <[DigestRow]> digest;
    in-out property <[TopicRow]> topics;
    in-out property <[ChatRow]> chat;
    in-out property <[string]> tracked-topics;
    in-out property <[string]> suggested-prompts;
    in-out property <[string]> suggested-topics;
    in-out property <[string]> delta-chips;
    in-out property <int> attention-budget: 5;
    in-out property <string> alert: "";
    in-out property <string> sysbar-time: "09:41";
    in-out property <EvidenceRow> evidence;
    in-out property <[EvidencePostRow]> evidence-posts;
    in-out property <bool> has-evidence: false;
    in-out property <bool> busy: false;
    in-out property <string> status: "";
    in-out property <bool> landscape: false;
    private property <int> active-tab: 0;
    private property <string> chat-input: "";

    callback refresh-requested();
    callback set-interest(string, float);
    callback set-budget(int);
    callback explain-requested(string);
    callback clear-evidence();
    callback subscribe-requested(string);
    callback send-message(string);
    callback open-url(string);
    callback rotate-requested();

    init => { Palette.color-scheme = Tokens.dark ? ColorScheme.dark : ColorScheme.light; }
    key-handler := FocusScope {
        KeyBinding {
            keys: @keys(Escape);
            activated => {
                if (root.has-evidence) { root.clear-evidence(); }
            }
        }
        KeyBinding {
            keys: @keys(Control + R);
            activated => { root.rotate-requested(); }
        }
    }

    Rectangle {
        x: 4px;
        y: 4px;
        width: parent.width - 8px;
        height: parent.height - 8px;
        border-radius: 44px;
        background: #05070A;
        drop-shadow-blur: 8px;
        drop-shadow-offset-y: 2px;
        drop-shadow-color: #00000099;
    }

    phone-shell := Rectangle {
        x: 14px;
        y: 14px;
        width: root.landscape ? 844px : 390px;
        height: root.landscape ? 390px : 844px;
        border-radius: 36px;
        border-width: 1px;
        border-color: #3A414D;
        background: Tokens.ground;
        clip: true;

        VerticalLayout {
            spacing: 0px;
            PhoneStatusBar { time: root.sysbar-time; }
            MobileHeader {
                compact: root.landscape;
                count: root.digest.length;
                budget: root.attention-budget;
            }

        body := Rectangle {
            vertical-stretch: 1;
            background: Tokens.ground;

            if root.active-tab == 0: VerticalLayout {
                x: root.landscape ? 72px : 0px;
                width: root.landscape ? (body.width - 72px) * 0.55 : body.width;
                height: body.height;
                padding-left: 14px;
                padding-right: 14px;
                padding-top: 8px;
                padding-bottom: 8px;
                spacing: 8px;
                if root.alert != "": Rectangle {
                    height: 40px;
                    border-radius: 10px;
                    border-width: 1px;
                    border-color: Tokens.accent;
                    background: Tokens.accent-soft;
                    Text {
                        x: 11px;
                        width: parent.width - 22px;
                        text: "TRACKED ALERT  ·  " + root.alert;
                        color: Tokens.accent;
                        font-family: "JetBrains Mono";
                        font-size: 8.5px;
                        font-weight: 650;
                        wrap: word-wrap;
                        vertical-alignment: center;
                    }
                }
                HorizontalLayout {
                    height: 30px;
                    spacing: 6px;
                    for chip in root.delta-chips: Rectangle {
                        horizontal-stretch: 1;
                        border-radius: 14px;
                        border-width: 1px;
                        border-color: Tokens.line-strong;
                        background: Tokens.raised;
                        Text {
                            text: chip;
                            color: Tokens.ink-2;
                            font-family: "JetBrains Mono";
                            font-size: 7.5px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            overflow: elide;
                        }
                    }
                }
                pulse-scroll := ScrollView {
                    vertical-stretch: 1;
                    pulse-list := VerticalLayout {
                        width: pulse-scroll.width;
                        spacing: 9px;
                        for card[index] in root.digest: MobileDigestCard {
                            width: pulse-list.width;
                            data: card;
                            rank: index + 1;
                            selected: root.has-evidence && root.evidence.id == card.id;
                            explain => { root.explain-requested(card.id); }
                            subscribe => { root.subscribe-requested(card.id); }
                            open-url(url) => { root.open-url(url); }
                        }
                    }
                }
            }

            if root.active-tab == 1: VerticalLayout {
                x: root.landscape ? 72px + (body.width - 72px - min(560px, body.width - 72px)) / 2 : 0px;
                width: root.landscape ? min(560px, body.width - 72px) : body.width;
                height: body.height;
                padding: 14px;
                spacing: 9px;
                HorizontalLayout {
                    height: 25px;
                    MobileMonoLabel { text: "THE MIX"; horizontal-stretch: 1; }
                    Text { text: "touch to tune"; color: Tokens.ink-3; font-family: "JetBrains Mono"; font-size: 8px; }
                }
                mix-scroll := ScrollView {
                    vertical-stretch: 1;
                    mix-list := VerticalLayout {
                        width: mix-scroll.width;
                        spacing: 9px;
                        for topic in root.topics: MobileTopicChannel {
                            width: mix-list.width;
                            data: topic;
                            set-weight(weight) => { root.set-interest(topic.id, weight); }
                        }
                        MobileMonoLabel { text: "SUGGESTED"; }
                        HorizontalLayout {
                            height: 32px;
                            spacing: 6px;
                            for topic in root.suggested-topics: Rectangle {
                                horizontal-stretch: 1;
                                border-radius: 16px;
                                border-width: 1px;
                                border-color: Tokens.line-strong;
                                background: transparent;
                                Text {
                                    text: "+ " + topic;
                                    color: Tokens.ink-2;
                                    font-family: "JetBrains Mono";
                                    font-size: 8px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                    overflow: elide;
                                }
                                TouchArea { clicked => { root.set-interest(topic, 1.0); } }
                            }
                        }
                    }
                }
                MobileAttentionBudgetMaster {
                    budget: root.attention-budget;
                    count: root.digest.length;
                    set-budget(budget) => { root.set-budget(budget); }
                }
            }

            if root.active-tab == 2: VerticalLayout {
                x: root.landscape ? 72px + (body.width - 72px - min(560px, body.width - 72px)) / 2 : 0px;
                width: root.landscape ? min(560px, body.width - 72px) : body.width;
                height: body.height;
                padding: 14px;
                spacing: 10px;
                HorizontalLayout {
                    height: 22px;
                    MobileMonoLabel { text: "PULSE AGENT"; horizontal-stretch: 1; }
                    Text { text: root.busy ? "thinking…" : "shared state"; color: Tokens.ink-3; font-family: "JetBrains Mono"; font-size: 8px; }
                }
                agent-scroll := ScrollView {
                    vertical-stretch: 1;
                    agent-list := VerticalLayout {
                        width: agent-scroll.width;
                        spacing: 12px;
                        for message in root.chat: MobileChatMessage {
                            width: agent-list.width;
                            data: message;
                        }
                    }
                }
                HorizontalLayout {
                    height: 29px;
                    spacing: 5px;
                    for prompt in root.suggested-prompts: Rectangle {
                        horizontal-stretch: 1;
                        border-radius: 14px;
                        background: Tokens.raised;
                        border-width: 1px;
                        border-color: Tokens.line;
                        Text { text: prompt; color: Tokens.ink-2; font-size: 8px; horizontal-alignment: center; vertical-alignment: center; overflow: elide; }
                        TouchArea { clicked => { root.send-message(prompt); } }
                    }
                }
                Rectangle {
                    height: 46px;
                    border-radius: 12px;
                    border-width: 1px;
                    border-color: Tokens.line-strong;
                    background: Tokens.raised;
                    LineEdit {
                        x: 8px;
                        y: 4px;
                        width: parent.width - 52px;
                        height: parent.height - 8px;
                        text <=> root.chat-input;
                        placeholder-text: "Ask what is moving…";
                        accepted => {
                            if (root.chat-input != "") {
                                root.send-message(root.chat-input);
                                root.chat-input = "";
                            }
                        }
                    }
                    Rectangle {
                        x: parent.width - 40px;
                        y: 6px;
                        width: 34px;
                        height: 34px;
                        border-radius: 10px;
                        background: Tokens.accent;
                        Text { text: "↑"; color: #FFFFFF; font-size: 17px; font-weight: 700; horizontal-alignment: center; vertical-alignment: center; }
                        TouchArea {
                            clicked => {
                                if (root.chat-input != "") {
                                    root.send-message(root.chat-input);
                                    root.chat-input = "";
                                }
                            }
                        }
                    }
                }
            }

            if root.landscape: Rectangle {
                x: 0px;
                y: 0px;
                width: 72px;
                height: parent.height;
                background: Tokens.surface;
                Rectangle {
                    x: parent.width - 1px;
                    width: 1px;
                    height: parent.height;
                    background: Tokens.line;
                }
                VerticalLayout {
                    padding-top: 8px;
                    padding-bottom: 18px;
                    spacing: 4px;
                    for tab[index] in ["PULSE", "MIX", "AGENT"]: Rectangle {
                        vertical-stretch: 1;
                        background: root.active-tab == index ? Tokens.accent-soft : transparent;
                        border-radius: 10px;
                        Text {
                            text: (index == 0 ? "⌁\n" : index == 1 ? "≡\n" : "◇\n") + tab;
                            color: root.active-tab == index ? Tokens.accent : Tokens.ink-3;
                            font-family: "JetBrains Mono";
                            font-size: 8px;
                            font-weight: 700;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                        TouchArea { clicked => { root.active-tab = index; } }
                    }
                }
                Rectangle {
                    x: 18px;
                    y: parent.height - 9px;
                    width: 36px;
                    height: 4px;
                    border-radius: 2px;
                    background: Tokens.ink-2;
                }
            }
        }

            if !root.landscape: Rectangle {
                height: 70px;
                background: Tokens.surface;
                Rectangle { y: 0; width: parent.width; height: 1px; background: Tokens.line; }
                HorizontalLayout {
                    height: 57px;
                padding-left: 14px;
                padding-right: 14px;
                spacing: 8px;
                for tab[index] in ["PULSE", "MIX", "AGENT"]: Rectangle {
                    horizontal-stretch: 1;
                    background: transparent;
                    Text {
                        text: (index == 0 ? "⌁\n" : index == 1 ? "≡\n" : "◇\n") + tab;
                        color: root.active-tab == index ? Tokens.accent : Tokens.ink-3;
                        font-family: "JetBrains Mono";
                        font-size: 9px;
                        font-weight: 700;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                    TouchArea { clicked => { root.active-tab = index; } }
                }
                }
                Rectangle {
                    x: (parent.width - self.width) / 2;
                    y: parent.height - 9px;
                    width: 108px;
                    height: 4px;
                    border-radius: 2px;
                    background: Tokens.ink-2;
                }
            }
        }

        Rectangle {
            width: parent.width;
            height: parent.height;
            background: #00000088;
            opacity: root.has-evidence ? 1 : 0;
            TouchArea {
                enabled: root.has-evidence;
                clicked => { root.clear-evidence(); }
            }
            animate opacity { duration: 140ms; }
        }
        evidence-sheet := MobileEvidenceSheet {
            x: root.landscape
                ? (root.has-evidence ? parent.width - 340px : parent.width)
                : 6px;
            y: root.landscape ? 0px : (root.has-evidence ? parent.height - self.height : parent.height);
            width: root.landscape ? 340px : parent.width - 12px;
            side-panel: root.landscape;
            available-height: parent.height;
            data: root.evidence;
            posts: root.evidence-posts;
            close => { root.clear-evidence(); }
            open-url(url) => { root.open-url(url); }
            animate x { duration: 180ms; easing: ease-in-out; }
            animate y { duration: 180ms; easing: ease-in-out; }
        }
    }

    Rectangle {
        x: parent.width - 34px;
        y: parent.height - 34px;
        width: 22px;
        height: 22px;
        border-radius: 11px;
        border-width: 1px;
        border-color: #556173;
        background: #1B212B;
        Text {
            text: "↻";
            color: Tokens.ink-2;
            font-size: 13px;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
        TouchArea {
            mouse-cursor: pointer;
            clicked => { root.rotate-requested(); }
        }
    }
}
