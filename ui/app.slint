import { LineEdit, ScrollView } from "std-widgets.slint";

export global Tokens {
    in property <color> ground: #EDF0F4;
    in property <color> surface: #FFFFFF;
    in property <color> raised: #F6F8FB;
    in property <color> inset: #E7EBF1;
    in property <color> line: #D7DDE6;
    in property <color> line-strong: #C2CAD7;
    in property <color> ink: #1A2230;
    in property <color> ink-2: #54617A;
    in property <color> ink-3: #8792A3;
    in property <color> accent: #B97C1E;
    in property <color> accent-soft: #F6ECDD;
    in property <color> ok: #1E7A44;
    in property <color> rust: #C07C15;
    in property <color> local: #008A66;
    in property <color> ai: #6D55D9;
    in property <color> wasm: #C24D75;
    in property <color> steel: #3D6FA8;
}

export struct DigestRow {
    id: string,
    topic: string,
    headline: string,
    sources: string,
    score: string,
    delta: string,
    mentions: string,
}

export struct TopicRow {
    id: string,
    topic: string,
    weight: string,
    state: string,
    weight-value: float,
    active: bool,
    muted: bool,
}

export struct ChatRow {
    role: string,
    body: string,
    tool: string,
}

export struct EvidenceRow {
    topic: string,
    velocity: string,
    baseline: string,
    z-score: string,
    sparkline: string,
    posts: string,
}

component MonoLabel inherits Text {
    color: Tokens.ink-3;
    font-family: "Noto Sans Mono";
    font-size: 9.5px;
    font-weight: 700;
    letter-spacing: 1.2px;
}

component FlatAction inherits Rectangle {
    in property <string> text;
    in property <bool> active: false;
    callback clicked();

    height: 27px;
    border-radius: 7px;
    border-width: 1px;
    border-color: active ? Tokens.accent : Tokens.line-strong;
    background: touch.has-hover ? (active ? Tokens.accent-soft : Tokens.raised) : Tokens.surface;

    Text {
        text: root.text;
        color: active ? Tokens.accent : Tokens.ink-2;
        font-family: "Noto Sans Mono";
        font-size: 10px;
        font-weight: 600;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    touch := TouchArea {
        clicked => { root.clicked(); }
    }
}

component TopicChannel inherits Rectangle {
    in property <TopicRow> data;
    in property <color> topic-color: data.id == "rust" ? Tokens.rust :
        data.id == "local-first" ? Tokens.local :
        data.id == "ai-infra" ? Tokens.ai :
        data.id == "wasm-runtimes" ? Tokens.wasm : Tokens.steel;
    in property <float> visual-weight: data.muted ? 0.0 :
        (data.weight-value > 0.0 ? data.weight-value / 2.0 : 0.42);
    callback set-weight(float);

    height: 67px;
    border-radius: 10px;
    border-width: 1px;
    border-color: Tokens.line;
    background: Tokens.surface;

    Rectangle {
        x: 0;
        width: 3px;
        height: parent.height;
        border-radius: 2px;
        background: root.topic-color;
        opacity: data.muted ? 0.32 : 1;
    }

    VerticalLayout {
        padding-left: 13px;
        padding-right: 11px;
        padding-top: 9px;
        padding-bottom: 10px;
        spacing: 7px;

        HorizontalLayout {
            spacing: 8px;
            Text {
                text: data.id == "wasm-runtimes" ? "wasm" : data.id;
                color: data.muted ? Tokens.ink-3 : Tokens.ink;
                font-family: "Noto Sans Mono";
                font-size: 11px;
                font-weight: 700;
                vertical-alignment: center;
                horizontal-stretch: 1;
            }
            Text {
                text: data.muted ? "off" : (data.weight-value > 0.0 ? data.weight : "0.5");
                color: data.muted ? Tokens.ink-3 : Tokens.ink-2;
                font-family: "Noto Sans Mono";
                font-size: 10px;
                vertical-alignment: center;
            }
            mute := Rectangle {
                width: 22px;
                height: 22px;
                border-radius: 6px;
                border-width: 1px;
                border-color: data.muted ? root.topic-color : Tokens.line-strong;
                background: data.muted ? root.topic-color : Tokens.raised;
                Text {
                    text: "M";
                    color: data.muted ? #FFFFFF : Tokens.ink-2;
                    font-family: "Noto Sans Mono";
                    font-size: 9px;
                    font-weight: 700;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
                TouchArea {
                    clicked => { root.set-weight(data.muted ? 0.0 : -1.0); }
                }
            }
        }

        fader := Rectangle {
            height: 14px;
            background: transparent;
            Rectangle {
                x: 0;
                y: 5px;
                width: parent.width;
                height: 4px;
                border-radius: 2px;
                background: Tokens.inset;
            }
            Rectangle {
                x: 0;
                y: 5px;
                width: parent.width * root.visual-weight;
                height: 4px;
                border-radius: 2px;
                background: root.topic-color;
                opacity: data.muted ? 0.25 : 0.82;
            }
            Rectangle {
                x: (parent.width - self.width) * root.visual-weight;
                y: 1px;
                width: 12px;
                height: 12px;
                border-radius: 6px;
                border-width: 2px;
                border-color: data.muted ? Tokens.ink-3 : root.topic-color;
                background: Tokens.surface;
            }
            TouchArea {
                clicked => {
                    root.set-weight(self.mouse-x / self.width * 2.0);
                }
            }
        }
    }
}

component EvidencePanel inherits Rectangle {
    in property <EvidenceRow> data;

    height: 258px;
    border-radius: 9px;
    background: Tokens.raised;
    border-width: 1px;
    border-color: Tokens.line;

    VerticalLayout {
        padding: 13px;
        spacing: 9px;

        HorizontalLayout {
            MonoLabel { text: "EVIDENCE"; horizontal-stretch: 1; }
            Text {
                text: data.z-score;
                color: Tokens.accent;
                font-family: "Noto Sans Mono";
                font-size: 10px;
                font-weight: 700;
            }
        }

        Rectangle {
            height: 58px;
            background: transparent;
            Rectangle {
                x: 0;
                y: 43px;
                width: parent.width;
                height: 1px;
                background: Tokens.line;
            }
            Text {
                text: data.sparkline;
                color: Tokens.accent;
                font-family: "Noto Sans Mono";
                font-size: 30px;
                vertical-alignment: bottom;
                letter-spacing: 3px;
            }
            Text {
                text: "7-day baseline";
                x: parent.width - self.width;
                y: 45px;
                color: Tokens.ink-3;
                font-family: "Noto Sans Mono";
                font-size: 8px;
            }
        }

        HorizontalLayout {
            spacing: 15px;
            Text { text: data.velocity; color: Tokens.ink-2; font-family: "Noto Sans Mono"; font-size: 9.5px; }
            Text { text: data.baseline; color: Tokens.ink-3; font-family: "Noto Sans Mono"; font-size: 9.5px; }
        }

        Rectangle {
            height: 50px;
            border-radius: 7px;
            background: Tokens.surface;
            border-width: 1px;
            border-color: Tokens.line;
            Text {
                x: 10px;
                y: 7px;
                width: parent.width - 20px;
                height: parent.height - 14px;
                text: data.posts;
                color: Tokens.ink-2;
                font-size: 10px;
                wrap: word-wrap;
                overflow: elide;
            }
        }

        Text {
            text: "score = recent velocity ÷ seven-day baseline";
            color: Tokens.ink-3;
            font-family: "Noto Sans Mono";
            font-size: 8.5px;
        }
    }
}

component DigestCard inherits Rectangle {
    in property <DigestRow> data;
    in property <EvidenceRow> evidence;
    in property <bool> selected: false;
    in property <int> rank: 1;
    in property <color> topic-color: data.id == "rust" ? Tokens.rust :
        data.id == "local-first" ? Tokens.local :
        data.id == "ai-infra" ? Tokens.ai :
        data.id == "wasm-runtimes" ? Tokens.wasm : Tokens.steel;
    callback explain();
    callback subscribe();

    height: selected ? 366px : 84px;
    border-radius: 12px;
    border-width: 1px;
    border-color: selected ? Tokens.accent : Tokens.line;
    background: Tokens.surface;

    VerticalLayout {
        padding: 13px;
        spacing: 10px;

        HorizontalLayout {
            spacing: 12px;

            Text {
                text: rank;
                width: 20px;
                color: Tokens.ink-3;
                font-family: "Noto Sans Mono";
                font-size: 12px;
                font-weight: 700;
                vertical-alignment: top;
            }

            VerticalLayout {
                spacing: 7px;
                horizontal-stretch: 1;

                HorizontalLayout {
                    spacing: 8px;
                    Rectangle {
                        width: 8px;
                        height: 8px;
                        y: 4px;
                        border-radius: 2px;
                        background: root.topic-color;
                    }
                    Text {
                        text: data.headline;
                        color: Tokens.ink;
                        font-size: 14.5px;
                        font-weight: 650;
                        overflow: elide;
                        horizontal-stretch: 1;
                    }
                }

                HorizontalLayout {
                    spacing: 8px;
                    Text {
                        text: data.sources + "  ·  " + data.mentions;
                        color: Tokens.ink-3;
                        font-size: 10px;
                        overflow: elide;
                        horizontal-stretch: 1;
                    }
                    Text {
                        text: selected ? "close" : "why?";
                        color: Tokens.ink-2;
                        font-family: "Noto Sans Mono";
                        font-size: 9.5px;
                        TouchArea { clicked => { root.explain(); } }
                    }
                }
            }

            VerticalLayout {
                width: 104px;
                spacing: 4px;
                Text {
                    text: "▁▂▂▃▂▄▅▇";
                    color: root.topic-color;
                    font-family: "Noto Sans Mono";
                    font-size: 17px;
                    horizontal-alignment: right;
                }
                Text {
                    text: data.delta;
                    color: Tokens.ink-2;
                    font-family: "Noto Sans Mono";
                    font-size: 9.5px;
                    font-weight: 700;
                    horizontal-alignment: right;
                }
            }
        }

        if selected: EvidencePanel {
            data: root.evidence;
        }
    }
}

component ChatMessage inherits Rectangle {
    in property <ChatRow> data;

    height: data.role == "TOOL" ? 45px : 66px;
    background: transparent;

    VerticalLayout {
        spacing: 5px;
        MonoLabel {
            text: data.role;
            color: data.role == "YOU" ? Tokens.steel :
                data.role == "TOOL" ? Tokens.accent : Tokens.ink-3;
        }
        if data.role == "TOOL": Rectangle {
            height: 27px;
            background: Tokens.accent-soft;
            border-radius: 3px;
            Rectangle { x: 0; width: 3px; height: parent.height; background: Tokens.accent; }
            Text {
                x: 10px;
                width: parent.width - 20px;
                text: "↳ " + data.tool + "  ·  " + data.body;
                color: Tokens.accent;
                font-family: "Noto Sans Mono";
                font-size: 9px;
                vertical-alignment: center;
                overflow: elide;
            }
        }
        if data.role != "TOOL": Text {
            text: data.body;
            color: Tokens.ink-2;
            font-size: 12px;
            wrap: word-wrap;
            overflow: elide;
        }
    }
}

export component AppWindow inherits Window {
    title: "Community Pulse";
    preferred-width: 1480px;
    preferred-height: 900px;
    min-width: 1100px;
    min-height: 720px;
    background: Tokens.ground;
    default-font-family: "Noto Sans";

    in-out property <[DigestRow]> digest;
    in-out property <[TopicRow]> topics;
    in-out property <[ChatRow]> chat;
    in-out property <[string]> tracked-topics;
    in-out property <string> tracked-summary: "Nothing tracked yet";
    in-out property <[string]> suggested-prompts;
    in-out property <EvidenceRow> evidence;
    in-out property <bool> has-evidence: false;
    in-out property <bool> busy: false;
    in-out property <string> status: "";
    private property <string> chat-input: "";

    callback refresh-requested();
    callback set-interest(string, float);
    callback explain-requested(string);
    callback subscribe-requested(string);
    callback send-message(string);

    VerticalLayout {
        spacing: 0;

        Rectangle {
            height: 39px;
            background: Tokens.raised;
            border-width: 0px;
            HorizontalLayout {
                padding-left: 16px;
                padding-right: 17px;
                spacing: 8px;
                Rectangle { width: 11px; height: 11px; border-radius: 6px; background: #E16B62; }
                Rectangle { width: 11px; height: 11px; border-radius: 6px; background: #E1AD47; }
                Rectangle { width: 11px; height: 11px; border-radius: 6px; background: #52A56D; }
                Text {
                    text: "Community Pulse";
                    width: 112px;
                    color: Tokens.ink-2;
                    font-size: 11px;
                    font-weight: 600;
                    vertical-alignment: center;
                }
                Rectangle { horizontal-stretch: 1; background: transparent; }
                Rectangle {
                    width: 49px;
                    height: 20px;
                    border-radius: 10px;
                    background: #DCEFE3;
                    Text {
                        text: "●  LIVE";
                        color: Tokens.ok;
                        font-family: "Noto Sans Mono";
                        font-size: 8px;
                        font-weight: 700;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
            Rectangle { y: parent.height - 1px; height: 1px; width: parent.width; background: Tokens.line; }
        }

        Rectangle {
            height: 82px;
            background: Tokens.surface;
            HorizontalLayout {
                padding-left: 24px;
                padding-right: 24px;
                spacing: 20px;

                Rectangle {
                    width: 260px;
                    Text {
                        x: 0;
                        y: 15px;
                        width: parent.width;
                        height: 28px;
                        text: "Community Pulse";
                        color: Tokens.ink;
                        font-size: 22px;
                        font-weight: 680;
                        horizontal-alignment: left;
                    }
                    Text {
                        x: 0;
                        y: 47px;
                        width: parent.width;
                        height: 15px;
                        text: "trendforge  ·  6h window";
                        color: Tokens.ink-3;
                        font-family: "Noto Sans Mono";
                        font-size: 9.5px;
                        letter-spacing: 0.5px;
                        horizontal-alignment: left;
                    }
                }

                Rectangle {
                    horizontal-stretch: 1;
                    background: transparent;
                    Rectangle {
                        y: 20px;
                        height: 42px;
                        background: transparent;
                        Path {
                            width: parent.width;
                            height: parent.height;
                            stroke: Tokens.line-strong;
                            stroke-width: 2px;
                            fill: transparent;
                            commands: "M 0 25 L 24 25 L 35 21 L 45 28 L 57 25 L 78 25 L 88 5 L 101 39 L 113 18 L 124 25 L 149 25 L 159 22 L 169 27 L 181 25 L 210 25";
                        }
                        Path {
                            x: 0;
                            y: 24px;
                            width: 39px;
                            height: 2px;
                            stroke: Tokens.accent;
                            stroke-width: 2px;
                            fill: transparent;
                            commands: "M 0 1 L 39 1";
                        }
                    }
                }

                for metric[index] in ["items / 6h\n214", "surfaced\n5", "ingest\n12s ago"]: Rectangle {
                    width: index == 2 ? 83px : 70px;
                    background: transparent;
                    Text {
                        y: 26px;
                        width: parent.width;
                        height: 32px;
                        text: metric;
                        color: Tokens.ink-3;
                        font-family: "Noto Sans Mono";
                        font-size: 8px;
                        horizontal-alignment: right;
                    }
                }

                Rectangle {
                    width: 74px;
                    background: transparent;
                    FlatAction {
                        y: 27px;
                        text: root.busy ? "working…" : "refresh";
                        active: root.busy;
                        clicked => { if (!root.busy) { root.refresh-requested(); } }
                    }
                }
            }
            Rectangle { y: parent.height - 1px; height: 1px; width: parent.width; background: Tokens.line; }
        }

        HorizontalLayout {
            spacing: 0;
            vertical-stretch: 1;

            Rectangle {
                width: 262px;
                background: Tokens.raised;
                VerticalLayout {
                    padding-left: 18px;
                    padding-right: 18px;
                    padding-top: 17px;
                    padding-bottom: 14px;
                    spacing: 10px;

                    Rectangle {
                        height: 39px;
                        background: transparent;
                        MonoLabel {
                            x: 0;
                            y: 0;
                            width: parent.width / 2;
                            height: 13px;
                            text: "THE MIX";
                        }
                        Text {
                            x: parent.width / 2;
                            y: 0;
                            width: parent.width / 2;
                            height: 13px;
                            text: "your interests";
                            color: Tokens.ink-3;
                            font-family: "Noto Sans Mono";
                            font-size: 8.5px;
                            horizontal-alignment: right;
                        }
                        Text {
                            x: 0;
                            y: 24px;
                            width: parent.width;
                            height: 15px;
                            text: "Drag to tune what earns attention.";
                            color: Tokens.ink-2;
                            font-size: 10.5px;
                        }
                    }

                    Rectangle {
                        height: 371px;
                        vertical-stretch: 0;
                        background: transparent;
                        VerticalLayout {
                            spacing: 9px;
                            for topic in root.topics: TopicChannel {
                                data: topic;
                                set-weight(weight) => { root.set-interest(topic.id, weight); }
                            }
                        }
                    }

                    MonoLabel { text: "SUGGESTED"; }
                    VerticalLayout {
                        height: 87px;
                        vertical-stretch: 0;
                        spacing: 6px;
                        for topic in ["+ zig ▲2.2", "+ gpu-compute ▲1.4", "+ observability"]: Rectangle {
                            height: 25px;
                            width: topic == "+ gpu-compute ▲1.4" ? 132px : 112px;
                            border-radius: 12px;
                            border-width: 1px;
                            border-color: Tokens.line-strong;
                            background: transparent;
                            Text {
                                text: topic;
                                color: Tokens.ink-2;
                                font-family: "Noto Sans Mono";
                                font-size: 8.5px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                            TouchArea {
                                clicked => {
                                    root.subscribe-requested(topic == "+ zig ▲2.2" ? "zig" :
                                        topic == "+ gpu-compute ▲1.4" ? "gpu-compute" : "observability");
                                }
                            }
                        }
                    }

                    Rectangle { vertical-stretch: 1; background: transparent; }

                    HorizontalLayout {
                        MonoLabel { text: "ATTENTION BUDGET"; horizontal-stretch: 1; }
                        Text { text: "5 / 5"; color: Tokens.accent; font-family: "Noto Sans Mono"; font-size: 9px; font-weight: 700; }
                    }
                    HorizontalLayout {
                        height: 7px;
                        spacing: 3px;
                        for segment in [1, 2, 3, 4, 5]: Rectangle {
                            border-radius: 2px;
                            background: segment <= root.digest.length ? Tokens.accent : Tokens.inset;
                        }
                    }
                }
                Rectangle { x: parent.width - 1px; width: 1px; height: parent.height; background: Tokens.line; }
            }

            Rectangle {
                horizontal-stretch: 1;
                background: Tokens.ground;
                VerticalLayout {
                    padding: 18px;
                    spacing: 12px;
                    HorizontalLayout {
                        MonoLabel { text: "TODAY'S PULSE"; horizontal-stretch: 1; }
                        Text {
                            text: "5 of 214 items surfaced  ·  today";
                            color: Tokens.ink-3;
                            font-family: "Noto Sans Mono";
                            font-size: 8.5px;
                        }
                    }
                    ScrollView {
                        vertical-stretch: 1;
                        VerticalLayout {
                            spacing: 10px;
                            for card[index] in root.digest: DigestCard {
                                data: card;
                                rank: index + 1;
                                evidence: root.evidence;
                                selected: root.has-evidence && root.evidence.topic == card.topic;
                                explain => { root.explain-requested(card.id); }
                                subscribe => { root.subscribe-requested(card.id); }
                            }
                        }
                    }
                }
            }

            Rectangle {
                width: 344px;
                background: Tokens.ground;
                VerticalLayout {
                    padding-left: 18px;
                    padding-right: 18px;
                    padding-top: 17px;
                    padding-bottom: 14px;
                    spacing: 12px;

                    HorizontalLayout {
                        MonoLabel { text: "PULSE AGENT"; horizontal-stretch: 1; }
                        Text { text: "chat  ·  voice-ready"; color: Tokens.ink-3; font-family: "Noto Sans Mono"; font-size: 8.5px; }
                    }

                    ScrollView {
                        vertical-stretch: 1;
                        VerticalLayout {
                            spacing: 12px;
                            for message in root.chat: ChatMessage { data: message; }
                        }
                    }

                    HorizontalLayout {
                        spacing: 6px;
                        for prompt[index] in root.suggested-prompts: Rectangle {
                            height: 27px;
                            width: index == 0 ? 112px : (index == 1 ? 87px : 58px);
                            border-radius: 14px;
                            background: Tokens.raised;
                            border-width: 1px;
                            border-color: Tokens.line;
                            Text {
                                text: prompt;
                                color: Tokens.ink-2;
                                font-size: 9.5px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                            TouchArea { clicked => { root.send-message(prompt); } }
                        }
                    }

                    Rectangle {
                        height: 41px;
                        border-radius: 10px;
                        border-width: 1px;
                        border-color: Tokens.line-strong;
                        background: Tokens.raised;
                        Text {
                            x: 10px;
                            width: 17px;
                            text: "◉";
                            color: Tokens.ink-3;
                            font-size: 11px;
                            vertical-alignment: center;
                        }
                        LineEdit {
                            x: 31px;
                            y: 3px;
                            width: parent.width - 76px;
                            height: parent.height - 6px;
                            text <=> root.chat-input;
                            placeholder-text: "Ask what is moving…";
                            accepted => {
                                if (root.chat-input != "") {
                                    root.send-message(root.chat-input);
                                    root.chat-input = "";
                                }
                            }
                        }
                        Rectangle {
                            x: parent.width - 39px;
                            y: 5px;
                            width: 32px;
                            height: 31px;
                            border-radius: 8px;
                            background: Tokens.accent;
                            Text {
                                text: "↑";
                                color: #FFFFFF;
                                font-size: 17px;
                                font-weight: 700;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                            TouchArea {
                                clicked => {
                                    if (root.chat-input != "") {
                                        root.send-message(root.chat-input);
                                        root.chat-input = "";
                                    }
                                }
                            }
                        }
                    }
                }
                Rectangle { width: 1px; height: parent.height; background: Tokens.line; }
            }
        }

        Rectangle {
            height: 31px;
            background: Tokens.raised;
            border-width: 0px;
            HorizontalLayout {
                padding-left: 24px;
                padding-right: 24px;
                spacing: 17px;
                alignment: center;
                for source in ["● hn", "● lobste.rs", "● producthunt"]: Text {
                    text: source;
                    color: Tokens.ok;
                    font-family: "Noto Sans Mono";
                    font-size: 8.5px;
                }
                Text { text: "window 6h"; color: Tokens.ink-3; font-family: "Noto Sans Mono"; font-size: 8.5px; }
                Text { text: "engine 0.1.0"; color: Tokens.ink-3; font-family: "Noto Sans Mono"; font-size: 8.5px; }
                Text {
                    text: root.status;
                    color: Tokens.ink-3;
                    font-family: "Noto Sans Mono";
                    font-size: 8.5px;
                    horizontal-alignment: right;
                    overflow: elide;
                    horizontal-stretch: 1;
                }
            }
            Rectangle { height: 1px; width: parent.width; background: Tokens.line; }
        }
    }
}
