export global Tokens {
    in-out property <bool> dark: true;
    out property <color> ground: dark ? #101419 : #EDF0F4;
    out property <color> surface: dark ? #1B212B : #FFFFFF;
    out property <color> raised: dark ? #222A35 : #F6F8FB;
    out property <color> inset: dark ? #141922 : #E7EBF1;
    out property <color> line: dark ? #2C3644 : #D7DDE6;
    out property <color> line-strong: dark ? #3A4657 : #C2CAD7;
    out property <color> ink: dark ? #E9EDF3 : #1A2230;
    out property <color> ink-2: dark ? #9AA6B7 : #54617A;
    out property <color> ink-3: dark ? #5F6D80 : #8792A3;
    out property <color> accent: dark ? #EFA43F : #B97C1E;
    out property <color> accent-soft: dark ? #EFA43F24 : #B97C1E1F;
    out property <color> rise: dark ? #E09A38 : #B06F10;
    out property <color> rise-soft: dark ? #E09A381F : #B06F101F;
    out property <color> fall: dark ? #7C97C4 : #3D6FA8;
    out property <color> ok: dark ? #4CAF6E : #1E7A44;
    out property <color> ok-soft: dark ? #4CAF6E24 : #1E7A441F;
    out property <color> danger: dark ? #E16B62 : #B83B35;
    out property <color> rust: dark ? #C8822A : #C07C15;
    out property <color> local: dark ? #17A183 : #008A66;
    out property <color> ai: dark ? #8672E8 : #6D55D9;
    out property <color> wasm: dark ? #C75F81 : #C24D75;
    out property <color> steel: dark ? #4C82C4 : #3D6FA8;
}
